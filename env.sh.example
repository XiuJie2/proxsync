# PVE-NetBox Sync - Environment Variables (Example)
# Copy this file to env.sh and fill in your actual credentials

# NetBox API
export NB_API_URL="https://netbox.example.com"
export NB_API_TOKEN="your-netbox-api-token"

# PVE API
export PVE_API_HOST="pve.example.com"
export PVE_API_USER="root@pam"
export PVE_API_TOKEN="your-pve-token-name"
export PVE_API_SECRET="your-pve-token-secret"
export PVE_API_VERIFY_SSL="false"

# NetBox cluster ID (optional)
export NB_CLUSTER_ID="1"

# Telegram notifications (optional)
export TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234"
export TELEGRAM_CHAT_ID="-1001234567890"